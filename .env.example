# ============================================================
# SentryPass — variáveis para o docker-compose (EasyPanel)
# Copie para .env e preencha. NÃO versione o .env real.
# ============================================================

# ── Backend (runtime) ──
SUPABASE_URL=https://lgorgmwjzkwabfhdpiqa.supabase.co
# Pode ser a chave ANON. As leituras privilegiadas (perfil do morador) passam
# pela Edge Function lookup-plate, que usa a service_role dentro do Supabase.
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...sua-anon-key
ROBOFLOW_API_KEY=sua-chave-roboflow
ROBOFLOW_WORKSPACE=llativo
ROBOFLOW_WORKFLOW=custom-workflow-5
# Opcional — padrão: <SUPABASE_URL>/functions/v1/lookup-plate
# LOOKUP_FUNCTION_URL=https://lgorgmwjzkwabfhdpiqa.supabase.co/functions/v1/lookup-plate
# Domínio(s) do frontend autorizados no CORS (separe por vírgula). Use * só em teste.
CORS_ORIGINS=https://seu-frontend.easypanel.host

# ── Frontend (build-time) ──
# URL pública da API backend — embutida no bundle do navegador.
VITE_API_URL=https://seu-backend.easypanel.host
